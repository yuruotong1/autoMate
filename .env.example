# autoMate Cloud Vision — Environment Variables
#
# Cloud vision enables screen parsing (OmniParser V2) and action reasoning
# (UI-TARS, Qwen-VL, etc.) via HuggingFace Inference Endpoints.
# Zero local GPU required — all inference runs in the cloud.
#
# Copy this file to .env and fill in your values, or export them directly.

# --- Required ---

# HuggingFace API token (https://huggingface.co/settings/tokens)
AUTOMATE_HF_TOKEN=hf_your_token_here

# OmniParser-compatible screen parser endpoint URL
# Deploys with: microsoft/OmniParser-v2.0 on A10G (24GB)
AUTOMATE_SCREEN_PARSER_URL=https://your-omniparser-endpoint.us-east-1.aws.endpoints.huggingface.cloud

# OpenAI-compatible vision-language model endpoint URL (base, without /v1/...)
# Deploys with: ByteDance-Seed/UI-TARS-1.5-7B on L40S (48GB) via vLLM
AUTOMATE_ACTION_MODEL_URL=https://your-uitars-endpoint.us-east-1.aws.endpoints.huggingface.cloud

# Model name for the action model (must match the repo ID served by vLLM)
AUTOMATE_ACTION_MODEL_NAME=ByteDance-Seed/UI-TARS-1.5-7B

# --- Optional (for endpoint warmup/management) ---

# HuggingFace namespace (your username or org) for the Endpoints API
AUTOMATE_HF_NAMESPACE=your-hf-username

# Endpoint names (used by warm_endpoints to check status and wake them up)
AUTOMATE_SCREEN_PARSER_ENDPOINT=omniparser-v2
AUTOMATE_ACTION_MODEL_ENDPOINT=ui-tars-1-5-7b
